# === WARNING:
#  - ALWAYS check for duplications in the reverse_proxy entrypoint
#    otherwise one service could be shadowed by another
#  - always use an explicit alias with suffix _entrypoint
#    and which is sufficiently long to be unique
#    (so that a service cannot be shadowed by similarly named container)
#
#  Excemptions because we cannot control their aliases:
#  - nextcloud-aio-apache


# Backend

api.{$DOMAIN_LONG} {
    reverse_proxy smd-ka_backend_entrypoint:8090 {
        # X-Forwarded-For & X-Forwarded-Proto are set by default
        header_up X-Real-IP {remote_host}
    }
}


# Frontend

{$DOMAIN_LONG} {
    reverse_proxy smd-ka_frontend_entrypoint:3000 {
        # X-Forwarded-For & X-Forwarded-Proto are set by default
        header_up X-Real-IP {remote_host}
    }
}

# redirections
{$DOMAIN_SHORT}, www.{$DOMAIN_SHORT}, www.{$DOMAIN_LONG} {
    redir https://{$DOMAIN_LONG}{uri}
}

api.{$DOMAIN_SHORT} {
    redir https://api.{$DOMAIN_LONG}{uri}
}

# Redirect the lecture talk domain to this URL
# There a redirection to the next event is done
{$DOMAIN_LECTURE_TALK}, www.{$DOMAIN_LECTURE_TALK} {
    redir https://{$DOMAIN_LONG}/events/vortrag
}


{$DOMAIN_KINGS_CAFE} {
   reverse_proxy kings-cafe_frontend_entrypoint:3000
}


{$DOMAIN_HOFFNUNGSTAGE} {
    reverse_proxy hoffnungstage-2026_entrypoint:3000
}

www.{$DOMAIN_HOFFNUNGSTAGE} {
    redir https://{$DOMAIN_HOFFNUNGSTAGE}{uri}
}


# DokuWiki
# TO BE CHANGED TO wiki.smd-karlsruhe.de
wiki.{$DOMAIN_LONG} {
    reverse_proxy smd-ka_dokuwiki_entrypoint:8080 {
        # X-Forwarded-For & X-Forwarded-Proto are set by default
        header_up X-Real-IP {remote_host}
    }
}


# Authentik

auth.{$DOMAIN_LONG} {
    reverse_proxy authentik_entrypoint:9000 {
        # X-Forwarded-For & X-Forwarded-Proto are set by default
        header_up X-Real-IP {remote_host}
    }
}


# Nextcloud AiO

# we cannot easily reach the Nextcloud mastercontainer
# and really, we do not want to publish it anyway

cloud.{$DOMAIN_LONG} {
    # rely on Nextcloud keeping that name the same
    # reaching docker host’s localhost is hard to do
    reverse_proxy nextcloud-aio-apache:8081 {
        # X-Forwarded-For & X-Forwarded-Proto are set by default
        header_up X-Real-IP {remote_host}
    }
}
